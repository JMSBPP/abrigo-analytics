# Abrigo Analytics — environment template
#
# Copy this file to `.env` (gitignored) and fill in real values for any
# operations that need authentication. Cloners running `make data` to pull
# the public Tier 1 dataset do NOT need to set anything here.
#
# Loading: tools like direnv, python-dotenv, or `set -a; source .env; set +a`
# will export these into your shell. The `huggingface_hub` library reads
# HF_TOKEN automatically.

# --- HuggingFace (maintainers only — needed for `make publish`) -------------
# Write-scoped token from https://huggingface.co/settings/tokens
# Required ONLY by scripts/publish_to_hf.py; not needed for `make data`.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Celo RPC (Tier 2 on-chain ingest only) --------------------------------
# Any Forno / Quicknode / Alchemy endpoint. Public Forno is free + works.
CELO_RPC_URL=https://forno.celo.org
